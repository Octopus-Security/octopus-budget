# Budget Tracker Environment Variables
# Copy this file to .env and update the values

# Session secret for Express session (generate a random string)
SESSION_SECRET=your-random-secret-key-here

# JWT secret for API authentication (generate a random string)
JWT_SECRET=your-jwt-secret-key-here

# Port (default: 3000)
PORT=3000

# Machine-to-machine secret for /api/internal/* (cortex /purchase). Must match
# cortex's INTERNAL_SECRET. Leave blank to trust the docker network only.
INTERNAL_SECRET=

# Which user's budget receives internal purchase writes (default: psychopathy)
BUDGET_OWNER=psychopathy
