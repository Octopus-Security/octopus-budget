<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/theme.css?v=<%= Date.now() %>">
</head>
<body>
    <nav>
        <div class="container">
            <h1>💰 Budget Tracker</h1>
            <div class="nav-links">
                <a href="/">Dashboard</a>
                <a href="/graphs">📈 Trends</a>
                <a href="/settings">Settings</a>
                <button class="scratchpad-toggle" onclick="toggleCalculator()" title="Calculator">🔢 Calculator</button>
                <button class="scratchpad-toggle" onclick="toggleScratchpad()" title="Notes / Draw">✏️ Scratchpad</button>
                <a href="/logout">Logout (<%= user.username %>)</a>
            </div>
        </div>
    </nav>

    <!-- ── Calculator panel ─────────────────────────────────────────────── -->
    <!-- Critical layout inlined so it works even with stale CSS cache. -->
    <div id="calcPanel" aria-hidden="true"
         style="display:none;position:fixed;top:0;left:0;width:300px;max-width:100%;height:100%;background:#111;border-right:1px solid #1e1e1e;z-index:100000;box-shadow:6px 0 32px rgba(0,0,0,.7);flex-direction:column;overflow:hidden;">
        <div class="scratchpad-header">
            <span>🔢 Calculator</span>
            <button class="scratchpad-close" onclick="toggleCalculator()">✕</button>
        </div>
        <div style="flex:1;display:flex;flex-direction:column;padding:10px;gap:8px;min-height:0;">
            <div style="background:#0d0d0d;border-radius:8px;padding:14px 12px;display:flex;flex-direction:column;justify-content:flex-end;min-height:90px;flex-shrink:0;">
                <div id="calcExpr" style="font-size:12px;color:#444;min-height:16px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;text-align:right;"></div>
                <div id="calcValue" style="font-size:34px;font-weight:300;color:#fff;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;text-align:right;line-height:1.1;">0</div>
            </div>
            <div style="display:grid;grid-template-columns:repeat(4,1fr);grid-template-rows:repeat(5,1fr);gap:7px;flex:1;min-height:0;">
                <button class="calc-btn calc-fn" onclick="calcClear()">C</button>
                <button class="calc-btn calc-fn" onclick="calcBackspace()" style="font-size:16px;">⌫</button>
                <button class="calc-btn calc-fn" onclick="calcPercent()">%</button>
                <button class="calc-btn calc-op" onclick="calcOperator('÷')">÷</button>
                <button class="calc-btn" onclick="calcDigit('7')">7</button>
                <button class="calc-btn" onclick="calcDigit('8')">8</button>
                <button class="calc-btn" onclick="calcDigit('9')">9</button>
                <button class="calc-btn calc-op" onclick="calcOperator('×')">×</button>
                <button class="calc-btn" onclick="calcDigit('4')">4</button>
                <button class="calc-btn" onclick="calcDigit('5')">5</button>
                <button class="calc-btn" onclick="calcDigit('6')">6</button>
                <button class="calc-btn calc-op" onclick="calcOperator('−')">−</button>
                <button class="calc-btn" onclick="calcDigit('1')">1</button>
                <button class="calc-btn" onclick="calcDigit('2')">2</button>
                <button class="calc-btn" onclick="calcDigit('3')">3</button>
                <button class="calc-btn calc-op" onclick="calcOperator('+')">+</button>
                <button class="calc-btn calc-fn" onclick="calcToggleSign()">±</button>
                <button class="calc-btn" onclick="calcDigit('0')">0</button>
                <button class="calc-btn" onclick="calcDecimal()">.</button>
                <button class="calc-btn calc-eq" onclick="calcEquals()">=</button>
            </div>
        </div>
    </div>

    <!-- ── Scratchpad panel ─────────────────────────────────────────────── -->
    <!-- Critical layout is inlined so the panel pins right and stays hidden
         even if theme.css is stale/cached. JS toggles inline display directly. -->
    <div id="scratchpad" class="scratchpad-panel" aria-hidden="true"
         style="display:none; position:fixed; top:0; right:0; width:380px; max-width:100%; height:100%; background:#111; border-left:1px solid #1e1e1e; z-index:100000; box-shadow:-6px 0 32px rgba(0,0,0,0.7); flex-direction:column; overflow:hidden;">
        <div class="scratchpad-header">
            <span>🧮 Scratchpad</span>
            <div class="scratchpad-mode">
                <span class="mode-label">✏️ Type</span>
                <label class="mode-switch" title="Toggle draw mode">
                    <input type="checkbox" id="drawToggle" onchange="toggleDrawMode(this.checked)">
                    <span class="mode-slider"></span>
                </label>
                <span class="mode-label">🖊 Draw</span>
            </div>
            <button class="scratchpad-close" onclick="toggleScratchpad()">✕</button>
        </div>
        <div id="scratchpadType" class="scratchpad-body" style="flex:1; display:flex; flex-direction:column; min-height:0; overflow:hidden;">
            <textarea id="scratchText" placeholder="Type calculations or notes here…&#10;&#10;e.g.&#10;Paycheck: 1200&#10;Rent: -850&#10;CC min: -45&#10;Affirm: -37.50&#10;Remaining: 267.50"></textarea>
            <div class="draw-toolbar">
                <span style="font-size:11px;color:#666;flex:1;">Saved automatically</span>
                <button onclick="clearNotes()" style="font-size:11px;padding:4px 8px;">Clear</button>
            </div>
        </div>
        <div id="scratchpadDraw" class="scratchpad-body" style="display:none; flex:1; flex-direction:column; min-height:0; overflow:hidden;">
            <canvas id="drawCanvas"></canvas>
            <div class="draw-toolbar">
                <button onclick="setDrawColor('#2ecc71')" style="background:#2ecc71;width:22px;height:22px;border-radius:50%;border:2px solid #111;padding:0;"></button>
                <button onclick="setDrawColor('#ffffff')" style="background:#fff;width:22px;height:22px;border-radius:50%;border:2px solid #111;padding:0;"></button>
                <button onclick="setDrawColor('#ff7878')" style="background:#ff7878;width:22px;height:22px;border-radius:50%;border:2px solid #111;padding:0;"></button>
                <button onclick="setDrawColor('#f0c060')" style="background:#f0c060;width:22px;height:22px;border-radius:50%;border:2px solid #111;padding:0;"></button>
                <input type="range" id="brushSize" min="2" max="24" value="4" style="width:70px;">
                <button onclick="clearCanvas()" style="font-size:11px;padding:4px 8px;">Clear</button>
            </div>
        </div>
    </div>

    <div class="container">
        <h1 style="margin: 30px 0 20px;">Welcome, <%= user.username %>!</h1>

        <div class="summary-grid">
            <div class="summary-card debt">
                <h3>💳 Total Debt</h3>
                <% let totalOwed = 0; %>
                <% debts.forEach(debt => { totalOwed += debt.balance; }); %>
                <div class="amount">$<%= totalOwed.toFixed(2) %></div>
            </div>
            <div class="summary-card income">
                <h3>💵 Monthly Income</h3>
                <% let monthlyIncome = 0; %>
                <% income.forEach(item => { 
                    if (item.frequency === 'weekly') monthlyIncome += item.amount * 4.33;
                    else if (item.frequency === 'biweekly') monthlyIncome += item.amount * 2.166667;
                    else monthlyIncome += item.amount;
                }); %>
                <div class="amount">$<%= monthlyIncome.toFixed(2) %></div>
            </div>
            <div class="summary-card">
                <h3>🏦 Total in Accounts</h3>
                <% let totalBalance = 0; %>
                <% accounts.forEach(account => { totalBalance += account.balance; }); %>
                <div class="amount">$<%= totalBalance.toFixed(2) %></div>
            </div>
            <div class="summary-card">
                <h3>📊 Subscription Total</h3>
                <% let subscriptionTotal = 0; %>
                <% subscriptions.forEach(sub => {
                    let amount = sub.amount;
                    if (sub.frequency === 'daily') amount *= 30;
                    else if (sub.frequency === 'weekly') amount *= 4.33;
                    else if (sub.frequency === 'yearly') amount /= 12;
                    subscriptionTotal += amount;
                }); %>
                <div class="amount">$<%= subscriptionTotal.toFixed(2) %></div>
                <div class="stat-label"><%= subscriptions.length %> subscriptions/month</div>
            </div>
            <div class="summary-card debt">
                <h3>💸 This Month's Spend</h3>
                <div class="amount">$<%= monthlySpend.toFixed(2) %></div>
                <div class="stat-label"><%= transactions.filter(t => t.date && t.date.startsWith(new Date().toISOString().slice(0,7)) && t.amount > 0).length %> transactions</div>
            </div>
        </div>

        <!-- ── Upcoming payments ──────────────────────────────────────── -->
        <% if (upcoming.length > 0) { %>
        <div class="card upcoming-card">
            <h2>📅 Upcoming Payments <span style="font-size:0.8rem;color:#555;font-weight:400;">(next 60 days)</span></h2>
            <div class="upcoming-list">
            <% upcoming.forEach(p => {
                const urgency = p.daysAway <= 3 ? 'urgent' : p.daysAway <= 7 ? 'soon' : '';
                const dateStr = p.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
                const dayStr  = p.daysAway === 0 ? 'Today' : p.daysAway === 1 ? 'Tomorrow' : `${p.daysAway} days`;
            %>
                <div class="upcoming-item <%= urgency %>">
                    <div class="upcoming-info">
                        <span class="upcoming-name"><%= p.label %></span>
                        <span class="upcoming-date"><%= dateStr %></span>
                    </div>
                    <div class="upcoming-right">
                        <% if (p.amount) { %><span class="upcoming-amount">$<%= p.amount.toFixed(2) %></span><% } %>
                        <span class="upcoming-days <%= urgency %>"><%= dayStr %></span>
                    </div>
                </div>
            <% }) %>
            </div>
        </div>
        <% } %>

        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(500px, 1fr)); gap: 20px;">
            <!-- Subscriptions -->
            <div class="card" style="order:1">
                <h2>📺 Subscriptions</h2>
                <% if (subscriptions.length > 0) { %>
                <table>
                    <tr>
                        <th>Name</th>
                        <th>Amount</th>
                        <th>Frequency</th>
                        <th>Actions</th>
                    </tr>
                    <% subscriptions.forEach(subscription => { %>
                        <tr>
                            <td><%= subscription.name %></td>
                            <td>$<%= subscription.amount.toFixed(2) %></td>
                            <td><%= subscription.frequency %></td>
                            <td class="actions">
                                <a href="/subscriptions/edit/<%= subscription.id %>" class="edit-btn">Edit</a>
                                <a href="/subscriptions/delete/<%= subscription.id %>" class="delete-btn" onclick="return confirm('Delete this subscription?')">Delete</a>
                            </td>
                        </tr>
                    <% }); %>
                </table>
                <% } else { %>
                    <p class="empty-state">No subscriptions yet</p>
                <% } %>
                <h3 style="font-size: 1rem; margin-bottom: 15px; color: #aaa;">Add Subscription</h3>
                <form action="/subscriptions" method="post">
                    <div class="form-grid">
                        <div class="form-group">
                            <label>Name</label>
                            <input type="text" name="name" required>
                        </div>
                        <div class="form-group">
                            <label>Amount</label>
                            <input type="number" step="0.01" name="amount" required>
                        </div>
                        <div class="form-group">
                            <label>Frequency</label>
                            <select name="frequency">
                                <option value="daily">Daily</option>
                                <option value="weekly">Weekly</option>
                                <option value="monthly">Monthly</option>
                                <option value="yearly">Yearly</option>
                            </select>
                        </div>
                    </div>
                    <button type="submit">Add Subscription</button>
                </form>
            </div>

            <!-- Accounts -->
            <div class="card" style="order:3">
                <h2>🏦 Accounts</h2>
                <% if (accounts.length > 0) { %>
                <table>
                    <tr>
                        <th>Name</th>
                        <th>Balance</th>
                        <th>Actions</th>
                    </tr>
                    <% accounts.forEach(account => { %>
                        <tr>
                            <td><%= account.name %></td>
                            <td>$<%= account.balance.toFixed(2) %></td>
                            <td>
                                <a href="/accounts/delete/<%= account.id %>" class="delete-btn" onclick="return confirm('Delete this account?')">Delete</a>
                            </td>
                        </tr>
                    <% }); %>
                </table>
                <% } else { %>
                    <p class="empty-state">No accounts yet</p>
                <% } %>
                <h3 style="font-size: 1rem; margin-bottom: 15px; color: #aaa;">Add/Update Account</h3>
                <form action="/accounts" method="post">
                    <div class="form-grid">
                        <div class="form-group">
                            <label>Name</label>
                            <input type="text" name="name" required>
                        </div>
                        <div class="form-group">
                            <label>Balance</label>
                            <input type="number" step="0.01" name="balance" required>
                        </div>
                    </div>
                    <button type="submit">Add/Update</button>
                </form>
            </div>

            <!-- Income -->
            <div class="card" style="order:4">
                <h2>💵 Income</h2>
                <% if (income.length > 0) { %>
                <table>
                    <tr>
                        <th>Amount</th>
                        <th>Frequency</th>
                    </tr>
                    <% income.forEach(item => { %>
                        <tr>
                            <td>$<%= item.amount.toFixed(2) %></td>
                            <td><%= item.frequency %></td>
                        </tr>
                    <% }); %>
                </table>
                <% } else { %>
                    <p class="empty-state">No income entries yet</p>
                <% } %>
                <h3 style="font-size: 1rem; margin-bottom: 15px; color: #aaa;">Add/Update Income</h3>
                <form action="/income" method="post">
                    <div class="form-grid">
                        <div class="form-group">
                            <label>Amount</label>
                            <input type="number" step="0.01" name="amount" required>
                        </div>
                        <div class="form-group">
                            <label>Frequency</label>
                            <select name="frequency">
                                <option value="weekly">Weekly</option>
                                <option value="biweekly">Bi-weekly</option>
                                <option value="monthly">Monthly</option>
                            </select>
                        </div>
                    </div>
                    <button type="submit">Add/Update</button>
                </form>
            </div>

            <!-- Debts + Installments grouped into one column -->
            <div style="order:2; display:flex; flex-direction:column; gap:20px; min-width:0;">
            <div class="card">
                <h2>💳 Debts</h2>
                <% if (debts.length > 0) { %>
                <table>
                    <tr>
                        <th>Name</th>
                        <th>Balance</th>
                        <th>Credit Limit</th>
                        <th>Available</th>
                        <th>Actions</th>
                    </tr>
                    <% debts.forEach(debt => { %>
                        <%
                            const bal = debt.balance !== null && debt.balance !== undefined ? debt.balance : 0;
                            const lim = debt.credit_limit;
                            const avail = lim !== null && lim !== undefined ? lim - bal : null;
                            const util = lim ? Math.min(100, (bal / lim) * 100) : null;
                        %>
                        <tr>
                            <td><%= debt.name %></td>
                            <td>$<%= bal.toFixed(2) %></td>
                            <td><%= lim !== null && lim !== undefined ? '$' + lim.toFixed(2) : '—' %></td>
                            <td>
                                <% if (avail !== null) { %>
                                    <span style="color: <%= avail < 0 ? '#e55' : avail < lim * 0.2 ? '#e3b341' : '#3fb950' %>">
                                        $<%= avail.toFixed(2) %>
                                    </span>
                                    <div style="margin-top:4px;background:#222;border-radius:3px;height:5px;width:80px;overflow:hidden;">
                                        <div style="height:100%;width:<%= util.toFixed(0) %>%;background:<%= util > 80 ? '#e55' : util > 50 ? '#e3b341' : '#3fb950' %>;border-radius:3px;"></div>
                                    </div>
                                    <span style="font-size:11px;color:#666;"><%= util.toFixed(0) %>% used</span>
                                <% } else { %>
                                    <span style="color:#666;">—</span>
                                <% } %>
                            </td>
                            <td>
                                <a href="/debts/delete/<%= debt.id %>" class="delete-btn" onclick="return confirm('Delete this debt?')">Delete</a>
                            </td>
                        </tr>
                    <% }); %>
                </table>
                <% } else { %>
                    <p class="empty-state">No debts yet</p>
                <% } %>
                <h3 style="font-size: 1rem; margin-bottom: 15px; color: #aaa;">Add/Update Debt</h3>
                <form action="/debts" method="post">
                    <div class="form-grid">
                        <div class="form-group">
                            <label>Debt Name</label>
                            <input type="text" name="name" placeholder="e.g., Chase Visa" required>
                        </div>
                        <div class="form-group">
                            <label>Current Balance</label>
                            <input type="number" step="0.01" name="amount" placeholder="0.00" required>
                        </div>
                        <div class="form-group">
                            <label>Credit Limit <span style="color:#666;font-size:11px;">(optional)</span></label>
                            <input type="number" step="0.01" name="credit_limit" placeholder="0.00">
                        </div>
                        <div class="form-group">
                            <label>Min Payment <span style="color:#666;font-size:11px;">(optional)</span></label>
                            <input type="number" step="0.01" name="minimum_payment" placeholder="0.00">
                        </div>
                        <div class="form-group">
                            <label>Due Day <span style="color:#666;font-size:11px;">day of month 1–28</span></label>
                            <input type="number" min="1" max="28" name="due_day" placeholder="e.g. 15">
                        </div>
                    </div>
                    <button type="submit">Add/Update</button>
                </form>
            </div>

            <!-- ── Installments (Affirm / Klarna / BNPL) — grouped with Debts ── -->
            <div class="card">
                <h2>🛍 Installment Plans <span style="font-size:0.8rem;color:#555;font-weight:400;">Affirm · Klarna · BNPL</span></h2>

            <!-- Provider allowances: "used" is auto-summed from the plans below -->
            <div style="margin-bottom:20px;">
                <p style="font-size:12px;font-weight:600;color:#888;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:10px;">Allowances — used vs available</p>
                <% providers.forEach(p => { %>
                <div style="display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid #1a1a1a;flex-wrap:wrap;">
                    <div style="min-width:110px;display:flex;align-items:center;gap:7px;">
                        <% if (p.icon_url) { %>
                            <img src="<%= p.icon_url %>" style="width:20px;height:20px;object-fit:contain;border-radius:3px;vertical-align:middle;" onerror="this.style.display='none'">
                        <% } %>
                        <span style="font-weight:600;"><%= p.name %></span>
                        <% if (!p.builtin) { %>
                            <a href="/providers/delete/<%= p.id %>" style="color:#e55;font-size:11px;text-decoration:none;" onclick="return confirm('Remove <%= p.name %>? Plans stay, allowance tracking is removed.')">✕</a>
                        <% } %>
                    </div>
                    <% if (p.allowance > 0) { %>
                        <div style="flex:1;min-width:170px;">
                            <div style="display:flex;justify-content:space-between;font-size:12px;margin-bottom:3px;">
                                <span style="color:#ff7878;">$<%= p.used.toFixed(2) %> used</span>
                                <span style="color:#3fb950;">$<%= p.available.toFixed(2) %> left</span>
                            </div>
                            <div style="background:#222;border-radius:3px;height:6px;overflow:hidden;">
                                <div style="height:100%;width:<%= p.pct.toFixed(0) %>%;background:<%= p.pct > 80 ? '#e55' : p.pct > 50 ? '#e3b341' : '#3fb950' %>;"></div>
                            </div>
                            <span style="font-size:11px;color:#666;"><%= p.pct.toFixed(0) %>% of $<%= p.allowance.toFixed(2) %> allowance</span>
                        </div>
                    <% } else { %>
                        <span style="flex:1;min-width:170px;font-size:12px;color:#666;">$<%= p.used.toFixed(2) %> in active plans — set an allowance to track usage</span>
                    <% } %>
                    <form action="/providers" method="post" style="display:flex;flex-direction:column;gap:4px;margin:0;align-items:flex-end;">
                        <input type="hidden" name="name" value="<%= p.name %>">
                        <div style="display:flex;gap:6px;align-items:center;">
                            <input type="number" step="0.01" name="allowance" value="<%= p.allowance || '' %>" placeholder="allowance" style="width:110px;padding:6px 8px;font-size:13px;">
                            <button type="submit" style="padding:6px 12px;font-size:12px;">Set</button>
                        </div>
                        <input type="url" name="icon_url" value="<%= p.icon_url || '' %>" placeholder="icon URL (optional)" style="width:100%;max-width:236px;padding:4px 8px;font-size:11px;color:#888;background:#0d0d0d;border:1px solid #222;border-radius:4px;">
                    </form>
                </div>
                <% }) %>
                <!-- Add a custom provider -->
                <form action="/providers" method="post" style="display:flex;gap:6px;align-items:center;margin-top:10px;flex-wrap:wrap;">
                    <input type="text" name="name" placeholder="Add other provider (e.g. Sezzle)" style="flex:1;min-width:130px;padding:6px 8px;font-size:13px;">
                    <input type="number" step="0.01" name="allowance" placeholder="allowance" style="width:95px;padding:6px 8px;font-size:13px;">
                    <input type="url" name="icon_url" placeholder="icon URL" style="width:130px;padding:6px 8px;font-size:13px;">
                    <button type="submit" style="padding:6px 12px;font-size:12px;">+ Add</button>
                </form>
            </div>

            <% const providerIconMap = {}; providers.forEach(p => { providerIconMap[p.name.toLowerCase()] = p.icon_url; }); %>
            <% if (installments.length > 0) { %>
            <table>
                <tr>
                    <th>Name</th>
                    <th>Provider</th>
                    <th>Payment</th>
                    <th>Remaining</th>
                    <th>Total Left</th>
                    <th>Next Due</th>
                    <th>Actions</th>
                </tr>
                <% installments.forEach(inst => {
                    const left = inst.remaining_payments * inst.payment_amount;
                    const due  = new Date(inst.next_due_date + 'T00:00:00');
                    const today = new Date(); today.setHours(0,0,0,0);
                    const days = Math.round((due - today) / 86400000);
                    const dueLabel = days === 0 ? '<span style="color:#ff7878">Today</span>'
                                   : days < 0   ? `<span style="color:#ff7878">${Math.abs(days)}d overdue</span>`
                                   : days <= 3  ? `<span style="color:#f0c060">${days}d</span>`
                                   : `${days}d`;
                    const plow = (inst.provider || '').toLowerCase();
                    const pIcon = providerIconMap[plow];
                %>
                <tr>
                    <td><%= inst.name %></td>
                    <td style="white-space:nowrap;">
                        <% if (pIcon) { %>
                            <img src="<%= pIcon %>" style="width:14px;height:14px;object-fit:contain;border-radius:2px;vertical-align:middle;margin-right:4px;" onerror="this.style.display='none'">
                        <% } else { %><%= plow === 'affirm' ? '🟢' : plow === 'klarna' ? '🩷' : '💳 ' %><% } %>
                        <%= inst.provider %>
                    </td>
                    <td>$<%= inst.payment_amount.toFixed(2) %></td>
                    <td><%= inst.remaining_payments %> left</td>
                    <td>$<%= left.toFixed(2) %></td>
                    <td><%- dueLabel %> <span style="color:#555;font-size:11px;">(<%= due.toLocaleDateString('en-US',{month:'short',day:'numeric'}) %>)</span></td>
                    <td class="actions">
                        <a href="/installments/paid/<%= inst.id %>" class="edit-btn" onclick="return confirm('Mark payment made and advance due date?')">✓ Paid</a>
                        <a href="/installments/delete/<%= inst.id %>" class="delete-btn" onclick="return confirm('Remove this installment plan?')">Delete</a>
                    </td>
                </tr>
                <% }) %>
            </table>
            <% } else { %>
                <p class="empty-state">No installment plans yet</p>
            <% } %>
            <h3 style="font-size: 1rem; margin: 20px 0 15px; color: #aaa;">Add Plan</h3>
            <form action="/installments" method="post">
                <div class="form-grid">
                    <div class="form-group">
                        <label>Name</label>
                        <input type="text" name="name" placeholder="e.g., PS5 via Affirm" required>
                    </div>
                    <div class="form-group">
                        <label>Provider</label>
                        <select name="provider" id="providerSelect" onchange="toggleProviderOther(this.value)">
                            <% providers.forEach(p => { %>
                            <option value="<%= p.name %>"><%= p.name %></option>
                            <% }) %>
                            <option value="__other__">➕ Add other…</option>
                        </select>
                        <input type="text" name="provider_other" id="providerOther" placeholder="New provider name" style="display:none;margin-top:6px;">
                    </div>
                    <div class="form-group">
                        <label>Total Amount</label>
                        <input type="number" step="0.01" name="total_amount" placeholder="0.00" required>
                    </div>
                    <div class="form-group">
                        <label>Payment Amount</label>
                        <input type="number" step="0.01" name="payment_amount" placeholder="per payment" required>
                    </div>
                    <div class="form-group">
                        <label>Payments Remaining</label>
                        <input type="number" min="1" name="remaining_payments" placeholder="e.g. 3" required>
                    </div>
                    <div class="form-group">
                        <label>Frequency</label>
                        <select name="frequency">
                            <option value="biweekly">Bi-weekly (Pay in 4)</option>
                            <option value="monthly">Monthly</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Next Due Date</label>
                        <input type="date" name="next_due_date" required>
                    </div>
                </div>
                <button type="submit">Add Plan</button>
            </form>
            </div><!-- /installments card -->
            </div><!-- /debts + installments group -->

            <!-- Credit Scores -->
            <% const scoreColor = (s) => !s ? '#666' : s >= 740 ? '#3fb950' : s >= 670 ? '#e3b341' : s >= 580 ? '#f0a020' : '#ff7878'; %>
            <div class="card" style="order:5">
                <h2>📊 Credit Scores</h2>
                <div style="display:flex;gap:20px;flex-wrap:wrap;margin-bottom:16px;">
                    <div style="flex:1;min-width:110px;text-align:center;">
                        <div style="font-size:12px;color:#888;text-transform:uppercase;letter-spacing:0.05em;">TransUnion</div>
                        <div style="font-size:34px;font-weight:bold;color:<%= scoreColor(scores.transunion) %>;"><%= scores.transunion || '—' %></div>
                    </div>
                    <div style="flex:1;min-width:110px;text-align:center;">
                        <div style="font-size:12px;color:#888;text-transform:uppercase;letter-spacing:0.05em;">Equifax</div>
                        <div style="font-size:34px;font-weight:bold;color:<%= scoreColor(scores.equifax) %>;"><%= scores.equifax || '—' %></div>
                    </div>
                </div>
                <form action="/credit-scores" method="post">
                    <div class="form-grid">
                        <div class="form-group">
                            <label>TransUnion</label>
                            <input type="number" min="300" max="850" name="transunion" value="<%= scores.transunion || '' %>" placeholder="300–850">
                        </div>
                        <div class="form-group">
                            <label>Equifax</label>
                            <input type="number" min="300" max="850" name="equifax" value="<%= scores.equifax || '' %>" placeholder="300–850">
                        </div>
                    </div>
                    <button type="submit">Update Scores</button>
                </form>
            </div>
            <!-- Transactions -->
            <div class="card" style="order:6">
                <h2>💸 Transactions</h2>
                <% if (transactions.length > 0) { %>
                <div style="overflow-x:auto;max-height:340px;overflow-y:auto;">
                <table>
                    <tr>
                        <th>Date</th>
                        <th>Description</th>
                        <th>Category</th>
                        <th>Amount</th>
                        <th>Actions</th>
                    </tr>
                    <% transactions.forEach(t => {
                        const isExpense = t.amount > 0;
                        const amtColor = isExpense ? '#ff7878' : '#3fb950';
                        const sign = isExpense ? '−' : '+';
                    %>
                    <tr>
                        <td style="white-space:nowrap;font-size:13px;color:#888;"><%= t.date %></td>
                        <td><%= t.description %></td>
                        <td><span style="font-size:12px;color:#888;"><%= t.category || '—' %></span></td>
                        <td style="color:<%= amtColor %>;font-weight:600;white-space:nowrap;"><%= sign %>$<%= Math.abs(t.amount).toFixed(2) %></td>
                        <td class="actions">
                            <a href="/transactions/edit/<%= t.id %>" class="edit-btn">Edit</a>
                            <a href="/transactions/delete/<%= t.id %>" class="delete-btn" onclick="return confirm('Delete this transaction?')">Delete</a>
                        </td>
                    </tr>
                    <% }) %>
                </table>
                </div>
                <% } else { %>
                    <p class="empty-state">No transactions yet. Log your first expense below.</p>
                <% } %>
                <h3 style="font-size: 1rem; margin: 20px 0 15px; color: #aaa;">Log Transaction</h3>
                <datalist id="tx-categories">
                    <% [...new Set(transactions.filter(t=>t.category).map(t=>t.category))].forEach(c => { %>
                    <option value="<%= c %>">
                    <% }) %>
                </datalist>
                <form action="/transactions" method="post">
                    <div class="form-grid">
                        <div class="form-group">
                            <label>Description</label>
                            <input type="text" name="description" placeholder="e.g., Groceries at Walmart" required>
                        </div>
                        <div class="form-group">
                            <label>Amount <span style="color:#666;font-size:11px;">positive=expense, negative=refund</span></label>
                            <input type="number" step="0.01" name="amount" placeholder="0.00" required>
                        </div>
                        <div class="form-group">
                            <label>Category <span style="color:#666;font-size:11px;">(optional)</span></label>
                            <input type="text" name="category" list="tx-categories" placeholder="e.g., Groceries">
                        </div>
                        <div class="form-group">
                            <label>Date</label>
                            <input type="date" name="date" value="<%= new Date().toISOString().slice(0,10) %>">
                        </div>
                    </div>
                    <button type="submit">Log Transaction</button>
                </form>
            </div>
        </div><!-- /dashboard grid -->
    </div><!-- /container -->

    <script>
    // ── Installment provider "Add other" toggle ─────────────────────────────────
    function toggleProviderOther(val) {
        const other = document.getElementById('providerOther');
        if (!other) return;
        const show = val === '__other__';
        other.style.display = show ? 'block' : 'none';
        other.required = show;
    }

    // ── Scratchpad ──────────────────────────────────────────────────────────────
    // Non-modal side panel: driven by inline display so it works regardless of
    // theme.css. The app stays fully visible and clickable while it's open.
    const panel = document.getElementById('scratchpad');
    let isOpen = false;

    // Right-side panel on desktop, bottom sheet on phone/tablet.
    function applyPanelGeometry() {
        const mobile = window.innerWidth <= 640;
        if (mobile) {
            panel.style.width  = '100%';
            panel.style.height = '78vh';
            panel.style.top    = 'auto';
            panel.style.bottom = '0';
            panel.style.borderLeft = 'none';
            panel.style.borderTop  = '1px solid #1e1e1e';
        } else {
            panel.style.width  = '380px';
            panel.style.height = '100%';
            panel.style.top    = '0';
            panel.style.bottom = 'auto';
            panel.style.borderLeft = '1px solid #1e1e1e';
            panel.style.borderTop  = 'none';
        }
    }

    function toggleScratchpad() {
        isOpen = !isOpen;
        applyPanelGeometry();
        panel.style.display = isOpen ? 'flex' : 'none';
        panel.setAttribute('aria-hidden', !isOpen);
        if (isOpen) {
            const ta = document.getElementById('scratchText');
            ta.value = localStorage.getItem('scratchpad') || '';
            if (!drawMode) ta.focus();
            setTimeout(resizeCanvas, 20);
        }
    }

    function clearNotes() {
        if (!confirm('Clear the scratchpad notes?')) return;
        const ta = document.getElementById('scratchText');
        ta.value = '';
        localStorage.removeItem('scratchpad');
        ta.focus();
    }

    window.addEventListener('resize', () => {
        if (isOpen) { applyPanelGeometry(); resizeCanvas(); }
        if (calcOpen) applyCalcGeometry();
    });

    document.getElementById('scratchText').addEventListener('input', function() {
        localStorage.setItem('scratchpad', this.value);
    });

    // ── Draw mode ───────────────────────────────────────────────────────────────
    let drawMode = false;
    let painting = false;
    let drawColor = '#2ecc71';
    const canvas = document.getElementById('drawCanvas');
    const ctx = canvas.getContext('2d');

    function resizeCanvas() {
        if (!drawMode) return;
        const parent = canvas.parentElement;      // #scratchpadDraw
        const w = parent.clientWidth;
        const h = parent.clientHeight - 48;        // leave room for toolbar
        let img = null;
        try { img = ctx.getImageData(0, 0, canvas.width, canvas.height); } catch (e) {}
        canvas.width  = Math.max(w, 100);
        canvas.height = Math.max(h, 200);
        ctx.fillStyle = '#0d0d0d';
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        if (img) { try { ctx.putImageData(img, 0, 0); } catch (e) {} }
    }

    function toggleDrawMode(on) {
        drawMode = on;
        document.getElementById('scratchpadType').style.display = on ? 'none' : 'flex';
        document.getElementById('scratchpadDraw').style.display = on ? 'flex' : 'none';
        if (on) setTimeout(resizeCanvas, 20);
        else document.getElementById('scratchText').focus();
    }

    function setDrawColor(c) { drawColor = c; }
    function clearCanvas() {
        ctx.fillStyle = '#0d0d0d';
        ctx.fillRect(0, 0, canvas.width, canvas.height);
    }

    function getPos(e) {
        const r = canvas.getBoundingClientRect();
        const src = e.touches ? e.touches[0] : e;
        return { x: src.clientX - r.left, y: src.clientY - r.top };
    }

    canvas.addEventListener('mousedown',  e => { painting = true; const p = getPos(e); ctx.beginPath(); ctx.moveTo(p.x, p.y); });
    canvas.addEventListener('mousemove',  e => { if (!painting) return; const p = getPos(e); ctx.lineWidth = document.getElementById('brushSize').value; ctx.strokeStyle = drawColor; ctx.lineCap = 'round'; ctx.lineTo(p.x, p.y); ctx.stroke(); });
    canvas.addEventListener('mouseup',    () => { painting = false; });
    canvas.addEventListener('mouseleave', () => { painting = false; });
    canvas.addEventListener('touchstart', e => { e.preventDefault(); painting = true; const p = getPos(e); ctx.beginPath(); ctx.moveTo(p.x, p.y); }, { passive: false });
    canvas.addEventListener('touchmove',  e => { e.preventDefault(); if (!painting) return; const p = getPos(e); ctx.lineWidth = document.getElementById('brushSize').value; ctx.strokeStyle = drawColor; ctx.lineCap = 'round'; ctx.lineTo(p.x, p.y); ctx.stroke(); }, { passive: false });
    canvas.addEventListener('touchend',   () => { painting = false; });

    // ── Calculator ──────────────────────────────────────────────────────────────
    const calcPanelEl = document.getElementById('calcPanel');
    let calcOpen = false;
    let _c = { val: '0', operand: null, op: null, waiting: false, expr: '' };

    function applyCalcGeometry() {
        const mobile = window.innerWidth <= 640;
        if (mobile) {
            calcPanelEl.style.width  = '100%';
            calcPanelEl.style.height = '78vh';
            calcPanelEl.style.top    = 'auto';
            calcPanelEl.style.bottom = '0';
            calcPanelEl.style.borderRight = 'none';
            calcPanelEl.style.borderTop   = '1px solid #1e1e1e';
        } else {
            calcPanelEl.style.width  = '300px';
            calcPanelEl.style.height = '100%';
            calcPanelEl.style.top    = '0';
            calcPanelEl.style.bottom = 'auto';
            calcPanelEl.style.borderRight = '1px solid #1e1e1e';
            calcPanelEl.style.borderTop   = 'none';
        }
    }

    function toggleCalculator() {
        calcOpen = !calcOpen;
        applyCalcGeometry();
        calcPanelEl.style.display = calcOpen ? 'flex' : 'none';
        calcPanelEl.setAttribute('aria-hidden', !calcOpen);
        // On mobile, only one panel at a time
        if (calcOpen && window.innerWidth <= 640 && isOpen) {
            isOpen = false;
            panel.style.display = 'none';
            panel.setAttribute('aria-hidden', 'true');
        }
    }

    function _cu() {
        document.getElementById('calcValue').textContent = _c.val;
        document.getElementById('calcExpr').textContent  = _c.expr;
    }
    function _cc(a, b, op) {
        if (op === '+') return a + b;
        if (op === '−') return a - b;
        if (op === '×') return a * b;
        if (op === '÷') return b !== 0 ? a / b : Infinity;
        return b;
    }
    function _cf(n) {
        if (!isFinite(n)) return 'Error';
        return parseFloat(n.toPrecision(12)).toString();
    }
    function calcDigit(d) {
        if (!_c.waiting && _c.val.replace(/[^0-9]/g, '').length >= 12) return;
        _c.val = _c.waiting ? d : (_c.val === '0' ? d : _c.val + d);
        _c.waiting = false;
        _cu();
    }
    function calcDecimal() {
        if (_c.waiting) { _c.val = '0.'; _c.waiting = false; }
        else if (!_c.val.includes('.')) _c.val += '.';
        _cu();
    }
    function calcOperator(op) {
        const v = parseFloat(_c.val);
        if (_c.operand !== null && !_c.waiting) {
            const r = _cc(_c.operand, v, _c.op);
            _c.val = _cf(r);
            _c.operand = isFinite(r) ? r : null;
        } else {
            _c.operand = v;
        }
        _c.op = op; _c.waiting = true;
        _c.expr = _c.val + ' ' + op;
        _cu();
    }
    function calcEquals() {
        if (_c.operand === null || _c.waiting) return;
        const r = _cc(_c.operand, parseFloat(_c.val), _c.op);
        _c.val = _cf(r); _c.expr = ''; _c.operand = null; _c.op = null; _c.waiting = false;
        _cu();
    }
    function calcClear()      { _c = { val: '0', operand: null, op: null, waiting: false, expr: '' }; _cu(); }
    function calcToggleSign() { const v = parseFloat(_c.val); if (!isNaN(v) && v !== 0) _c.val = _cf(v * -1); _cu(); }
    function calcPercent()    { const v = parseFloat(_c.val); if (!isNaN(v)) _c.val = _cf(v / 100); _cu(); }
    function calcBackspace()  { if (_c.waiting) return; _c.val = _c.val.length > 1 ? _c.val.slice(0, -1) : '0'; _cu(); }

    document.addEventListener('keydown', e => {
        if (!calcOpen) return;
        const tag = document.activeElement?.tagName;
        if (tag === 'INPUT' || tag === 'TEXTAREA') return;
        if (e.key >= '0' && e.key <= '9')       { e.preventDefault(); calcDigit(e.key); }
        else if (e.key === '.')                   { e.preventDefault(); calcDecimal(); }
        else if (e.key === '+')                   { e.preventDefault(); calcOperator('+'); }
        else if (e.key === '-')                   { e.preventDefault(); calcOperator('−'); }
        else if (e.key === '*')                   { e.preventDefault(); calcOperator('×'); }
        else if (e.key === '/')                   { e.preventDefault(); calcOperator('÷'); }
        else if (e.key === 'Enter' || e.key === '=') { e.preventDefault(); calcEquals(); }
        else if (e.key === 'Backspace')           { e.preventDefault(); calcBackspace(); }
        else if (e.key === 'Escape')              { e.preventDefault(); toggleCalculator(); }
        else if (e.key === 'c' || e.key === 'C') { e.preventDefault(); calcClear(); }
    });
    </script>
</body>
</html>